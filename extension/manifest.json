{
  "manifest_version": 3,
  "name": "JazzWall",
  "description": "Capture Google Meet audio and stream it to JazzWall for live transcript + meeting intelligence.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "tabCapture"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://jazzwall.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "JazzWall Recorder"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jazzwall.vercel.app/*", "http://localhost:3000/*"],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
